{% template date %}
{% liquid
assign now_timestamp = trmnl.system.timestamp_utc
assign timestamp = datetime | date: "%s" | plus: 0
assign timezone_offset = trmnl.user.utc_offset | default: 0
assign today = now_timestamp | date: "%Y-%m-%d"
assign timestamp_day = timestamp | date: "%Y-%m-%d"
assign year = timestamp | date: "%Y" | plus: 0
assign current_year = now_timestamp | date: "%Y" | plus: 0
%}
{% if today == timestamp_day %}
{% assign format = trmnl.plugin_settings.custom_fields_values.time_format | default: "%I:%M %p" %}
{{ timestamp | plus: timezone_offset | date: format }}
{% elsif year == current_year %}
{{ timestamp | date: "%b %-d" }}
{% else %}
{% assign format =  trmnl.plugin_settings.custom_fields_values.date_format | default: "%m/%d/%Y" %}
{{ timestamp | date: format }}
{% endif %}
{% endtemplate %}

{% template stat_item %}
<div class="item stretch">
      <div class="meta"></div>
      <div class="content">
          <span class="title title--small">{{stat.label}}</span>
          {% if stat.title %}<span class="title title--small">{{stat.title}}</span>{% endif %}

            {% if stat.show.title %} <span class="title title--small">{{stat.show.title}}</span>{% endif %}
            {% if stat.movie.title %} <span class="title title--small">{{stat.movie.title}}</span>{% endif %}


                {% for val in stat.values %}
                <div class="description">{{val}}</div>
                {% endfor %}
            </span>
     </div>
</div>
{% endtemplate %}

{% template overview_item %}
{% if overview_text %}
<span class="description" data-clamp="{{desc_clamp}}" data-clamp-lg="{{desc_clamp_lg}}" data-clamp-portrait="{{desc_clamp_portrait}}" data-clamp-lg-portrait="{{desc_clamp_lg_portrait}}">{{overview_text | escape }}</span>
{% endif %}
{% endtemplate %}

{% template movie_item %}
<div class="flex flex--row flex--top gap--small movie_item">
  {% if movie.image_url and show_images != "false" %}
  <div style="position:relative;display:inline-block;flex-shrink:0;align-self:flex-start;overflow:hidden;">
    <img class="image image-dither image--contain {{img_class}}" src="{{movie.image_url}}"/>{% unless img_class == 'hidden' or img_class == ' hidden' %}
    <div class="image-badge">
    {{movie_icon}}
    </div>{% endunless %}</div>
  {% endif %}
  <div class="flex flex--col flex--top gap--none w--full h--full">
    <div class="label label--underline w--full text--left m--0" data-clamp="3">{% if movie.favorited %}★ {% endif %}{{movie.title}}</div>

    {% if movie.collected_at %}
    <div class="label label--small w--full text--left m--0" >
      Collected at {% render "date": datetime: movie.collected_at, trmnl:trmnl %}

    </div>
    {% endif %}
    {% if movie.released %}
    <div class="label label--small w--full text--left m--0" >
      Released at {% render "date": datetime: movie.released, trmnl:trmnl %}
    </div>

    {% endif %}
    <div class="label label--small w--full text--left m--0" ><strong class="w--full" >{{movie.year}}{% if movie.genres.size > 0 %} · Movie{% endif %}{% unless movie.progress %}
      {% if movie.watched_at %}
      ✔ {% render "date": datetime: movie.watched_at, trmnl:trmnl %}

      {% endif %}
       {% if movie.rating %} · ★ {{movie.rating}}/10{% endif %}{% endunless %}{% if movie.watchers %} · {{movie.watchers}} watching{% endif %}{% for g in movie.genres limit: 2 %} · {{g}}{% endfor %}</strong></div>

    {% render "overview_item", overview_text: movie.overview, desc_clamp: desc_clamp, desc_clamp_lg: desc_clamp_lg, desc_clamp_portrait: desc_clamp_portrait, desc_clamp_lg_portrait: desc_clamp_lg_portrait %}
  </div>
</div>
{% endtemplate %}

{% comment %}Unified show template — handles both show_group (episode list) and show (metadata) items.
  show_group items have: show.show (title), show.seasons (non-empty), show.show_progress, show.total_seasons
  show items have:       show.title, show.genres, show.overview, show.rating, show.network
  Both have: show.image_url, show.favorited, show.watchers{% endcomment %}
{% template show_item %}
{% assign _title = show.title | default: show.show %}
<div class="flex flex--row flex--top gap--small show_item">
  {% if show.image_url and show_images != "false" %}
  <div style="position:relative;display:inline-block;flex-shrink:0;align-self:flex-start;overflow:hidden;"><img class="image image--contain image-dither {{img_class}}" src="{{show.image_url}}"/>{% unless img_class == 'hidden' or img_class == ' hidden' %}
  <div class="image-badge">
  {{ show_icon }}
  </div>{% endunless %}</div>
  {% endif %}
  <div class="flex flex--col flex--top gap--none w--full h--full">
    <div class="label label--underline w--full text--left m--0">{% if show.favorited %}★ {% endif %}{{_title}}</div>
    {% if show.seasons.size > 0 %}
    {% comment %}Episode mode — show_group type{% endcomment %}
    {% for season in show.seasons | limit: 1 %}
    {% if season.progress and season.progress.completed > 0 %}
    <div class="label label--small w--full text--left m--0"><i>S{{season.number}}{% if show.total_seasons > 1 %} of {{show.total_seasons}}{% endif %} · E{{season.progress.completed}} of {{season.progress.aired}} {% if show.show_progress and show.show_progress.completed > 0 %} ({% assign _show_pct = show.show_progress.completed | times: 100 | divided_by: show.show_progress.aired %}{{_show_pct}}%{% endif %})</i></div>
    {% endif %}
    {% for ep in season.episodes | limit: 3 %}
    <div class="label label--small w--full text--left m--0"><strong data-clamp="3">
      {% if ep.airs_at %}
      {% render "date": datetime: ep.airs_at, trmnl:trmnl %}:
      {% endif %}
      S{{season.number}}E{{ep.episode}}: {{ep.title}}
      {% if ep.watched_at %}
      ✔ {% render "date": datetime: ep.watched_at, trmnl:trmnl %}
      {% endif %}
      {% if ep.progress %} ({{ep.progress}}%){% endif %}

    </strong></div>
    {% if season.episodes.size == 1 %}{% render "overview_item", overview_text: ep.overview, desc_clamp: desc_clamp, desc_clamp_lg: desc_clamp_lg, desc_clamp_portrait: desc_clamp_portrait, desc_clamp_lg_portrait: desc_clamp_lg_portrait %}{% endif %}
    {% endfor %}
    {% endfor %}
    {% else %}
    {% comment %}Show metadata mode — show type{% endcomment %}
    {% if show.collected_at %}
    <div class="label label--small w--full text--left m--0">Collected at {% render "date": datetime: show.collected_at, trmnl:trmnl %}</div>
    {% endif %}
    <div class="label label--small w--full text--left m--0"><strong data-clamp="3">
      {% if show.watched_at %}
      ✔ {% render "date": datetime: show.watched_at, trmnl:trmnl %}
      {% endif %}
      {% if show.progress %}({{show.progress}}%) {% endif %}{{show.year}}{% if show.genres.size > 0 %} · Show{% endif %}{% if show.rating %} · ★ {{show.rating}}/10{% endif %}{% if show.network %} · {{show.network}}{% endif %}{% if show.watchers %} · {{show.watchers}} watching{% endif %}{% for g in show.genres limit: 2 %} · {{g}}{% endfor %}</strong></div>
    {% render "overview_item", overview_text: show.overview, desc_clamp: desc_clamp, desc_clamp_lg: desc_clamp_lg, desc_clamp_portrait: desc_clamp_portrait, desc_clamp_lg_portrait: desc_clamp_lg_portrait %}
    {% endif %}
  </div>
</div>
{% endtemplate %}

{% template main %}
{% comment %}
Parameters from each view liquid:
img_class        — image size class, e.g. "w--24 h--auto"
cols             — grid columns at base breakpoint (default 2)
cols_lg          — grid columns at lg (default: cols)
cols_portrait    — grid columns at portrait base (default: cols)
cols_lg_portrait — grid columns at portrait lg (default: cols_lg)
items            — items per category at base breakpoint (default 4)
items_lg         — items per category at lg (default: items)
items_portrait   — items per category at portrait base (default: items)
items_lg_portrait — items per category at portrait lg (default: items_lg)
cats             — categories shown at base breakpoint (default 1)
cats_lg          — categories shown at lg (default: cats)
cats_portrait    — categories shown at portrait base (default: cats)
cats_lg_portrait — categories shown at portrait lg (default: cats_lg)
{% endcomment %}

{% comment %}— Columns —{% endcomment %}
{% assign _cols      = cols             | default: 2       | plus: 0 %}
{% assign _cols_lg   = cols_lg          | default: _cols    | plus: 0 %}
{% assign _cols_p    = cols_portrait    | default: _cols    | plus: 0 %}
{% assign _cols_lg_p = cols_lg_portrait | default: _cols_lg | plus: 0 %}

{% comment %}— Items per category —{% endcomment %}
{% assign _items      = items             | default: 4        | plus: 0 %}
{% assign _items_lg   = items_lg          | default: _items    | plus: 0 %}
{% assign _items_p    = items_portrait    | default: _items    | plus: 0 %}
{% assign _items_lg_p = items_lg_portrait | default: _items_lg | plus: 0 %}

{% comment %}— User settings —{% endcomment %}
{% assign _show_images = trmnl.plugin_settings.custom_fields_values.show_images | default: "true" %}

{% comment %}— Grid class —{% endcomment %}
{% assign _grid = "grid grid--cols-" | append: _cols %}
{% unless _cols_lg   == _cols    %}{% assign _grid = _grid | append: " lg:grid--cols-"         | append: _cols_lg   %}{% endunless %}
{% unless _cols_p == _cols and _cols_p == _cols_lg %}{% assign _grid = _grid | append: " portrait:grid--cols-" | append: _cols_p %}{% endunless %}
{% assign _eff_cols_lg_p = _cols %}{% if _cols_lg != _cols %}{% assign _eff_cols_lg_p = _cols_lg %}{% endif %}{% unless _cols_p == _cols and _cols_p == _cols_lg %}{% assign _eff_cols_lg_p = _cols_p %}{% endunless %}
{% unless _cols_lg_p == _eff_cols_lg_p %}{% assign _grid = _grid | append: " lg:portrait:grid--cols-" | append: _cols_lg_p %}{% endunless %}

{% assign max_items = _items %}
{% if _items_lg   > max_items %}{% assign max_items = _items_lg   %}{% endif %}
{% if _items_p    > max_items %}{% assign max_items = _items_p    %}{% endif %}
{% if _items_lg_p > max_items %}{% assign max_items = _items_lg_p %}{% endif %}

{% comment %}— Description clamp —{% endcomment %}
{% assign _dc    = desc_clamp             | default: 3 %}
{% assign _dc_lg = desc_clamp_lg          | default: _dc %}
{% assign _dc_p  = desc_clamp_portrait    | default: _dc %}
{% assign _dc_lp = desc_clamp_lg_portrait | default: _dc_lg %}
{% assign _boost    = desc_clamp_boost             | default: 0 %}
{% assign _boost_lg = desc_clamp_boost_lg          | default: _boost %}
{% assign _boost_p  = desc_clamp_boost_portrait    | default: _boost %}
{% assign _boost_lp = desc_clamp_boost_lg_portrait | default: _boost_lg %}
{% if _show_images == "false" %}
{% assign _dc    = _dc    | plus: _boost %}
{% assign _dc_lg = _dc_lg | plus: _boost_lg %}
{% assign _dc_p  = _dc_p  | plus: _boost_p %}
{% assign _dc_lp = _dc_lp | plus: _boost_lp %}
{% endif %}

<div class="layout layout--col m--0 p--0 layout--stretch">
  <div class="flex flex--col gap--none  h--full" data-overflow="true">

    {% for cat in data.categories %}
    {% if cat.items.size > 0 %}

    <div class="item h--min-40 m--1" style="flex-grow:0;align-items:stretch;border:2px solid #000;box-shadow:4px 4px 0 0 #000;">
      {% assign _title_len = cat.title | size %}{% if _title_len > 8 %}{% assign _bar_font = "font-size:0.7em;" %}{% elsif _title_len > 6 %}{% assign _bar_font = "font-size:0.75em;" %}{% else %}{% assign _bar_font = "" %}{% endif %}
      <div class="meta w--6 bg--black" 
        style="writing-mode:vertical-lr;letter-spacing:0.1em;font-weight:700;text-align:center;flex-shrink:0;color:white;background-color:black;margin:4px 0;{{_bar_font}}">{{cat.title | upcase}}</div>
      <div class="flex flex--row p--1 stretch" >

        <div class="{{_grid}} w--min-0 stretch" style="overflow:hidden;flex:1;padding-right:6px;padding-bottom:6px;">
          {% assign cat_items = cat.items %}
          {% for item in cat_items | limit: max_items %}

          {% comment %}— Item visibility class —{% endcomment %}
          {% assign _i_sm   = false %}{% assign _i_lg   = false %}
          {% assign _i_sm_p = false %}{% assign _i_lg_p = false %}
          {% if forloop.index <= _items      %}{% assign _i_sm   = true %}{% endif %}
            {% if forloop.index <= _items_lg   %}{% assign _i_lg   = true %}{% endif %}
              {% if forloop.index <= _items_p    %}{% assign _i_sm_p = true %}{% endif %}
                {% if forloop.index <= _items_lg_p %}{% assign _i_lg_p = true %}{% endif %}
                  {% if _i_sm %}{% assign _ic = "" %}{% else %}{% assign _ic = "hidden" %}{% endif %}
                  {% unless _i_lg   == _i_sm   %}{% if _i_lg   %}{% assign _ic = _ic | append: " lg:block"            %}{% else %}{% assign _ic = _ic | append: " lg:hidden"            %}{% endif %}{% endunless %}
                  {% unless _i_sm_p == _i_sm   %}{% if _i_sm_p %}{% assign _ic = _ic | append: " portrait:block"      %}{% else %}{% assign _ic = _ic | append: " portrait:hidden"      %}{% endif %}{% endunless %}
                  {% assign _eff_i_lg_p = _i_sm %}{% if _i_lg != _i_sm %}{% assign _eff_i_lg_p = _i_lg %}{% endif %}{% if _i_sm_p != _i_sm %}{% assign _eff_i_lg_p = _i_sm_p %}{% endif %}
                  {% unless _i_lg_p == _eff_i_lg_p %}{% if _i_lg_p %}{% assign _ic = _ic | append: " lg:portrait:block"   %}{% else %}{% assign _ic = _ic | append: " lg:portrait:hidden"   %}{% endif %}{% endunless %}
                  {% assign _ic = _ic | strip %}

                  <div{% if _ic != "" %} class="{{_ic}}"{% endif %}>
                    {% if item.type == "show_group" or item.type == "show" %}{% render "show_item", show: item, data: data, img_class: img_class, show_images: _show_images, desc_clamp: _dc, desc_clamp_lg: _dc_lg, desc_clamp_portrait: _dc_p, desc_clamp_lg_portrait: _dc_lp, trmnl:trmnl, show_icon: show_icon, movie_icon: movie_icon %}
                    {% elsif item.type == "movie" %}{% render "movie_item", movie: item, data: data, img_class: img_class, show_images: _show_images, desc_clamp: _dc, desc_clamp_lg: _dc_lg, desc_clamp_portrait: _dc_p, desc_clamp_lg_portrait: _dc_lp, trmnl:trmnl, show_icon: show_icon, movie_icon: movie_icon %}
                    {% elsif item.type == "stat" %}{% render "stat_item", stat: item, data: data, trmnl:trmnl, show_icon: show_icon, movie_icon: movie_icon %}
                    {% endif %}
                  </div>
                  {% endfor %}
                </div>
                </div>
                </div>

                  {% endif %}
                  {% endfor %}

                </div>
                </div>

                  <div class="title_bar">
                    <img class="image image-dither rounded" src="https://raw.githubusercontent.com/Taxel/PlexTraktSync/refs/heads/main/trakt.ico">
                    <span class="title">{% assign _iname = trmnl.plugin_settings.instance_name %}{% if _iname and _iname != 'Trakt.tv' %}{{_iname}}{% elsif data.user.username %}{% assign _ul = data.user.username | slice: -1 %}{{data.user.username}}{% if _ul == 's' or _ul == 'S' %}'{% else %}'s{% endif %} Trakt.tv{% else %}Trakt.tv{% endif %}</span>
                    <span class="instance {% if titlebar_instance_class %}{{titlebar_instance_class}}{% endif %}"></span>
                  </div>
                  {% endtemplate %}
