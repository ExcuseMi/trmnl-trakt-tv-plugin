{% assign _si = trmnl.plugin_settings.custom_fields_values.show_images | default: "true" %}
{% assign cats = data.categories.size %}
{% assign item_multiplier_lg = 1 %}
{% assign item_multiplier = 1 %}
{% assign item_multiplier_portrait = 1 %}
{% assign item_multiplier_lg_portrait = 1 %}

{% if cats == 2 %}
{% if _si == "false" %}
{% assign item_multiplier_lg = 2 %}

{% endif %}
{% assign item_multiplier_portrait = 2 %}

{% assign item_multiplier_lg_portrait = 2 %}

{% elsif cats == 1 %}
{% assign item_multiplier_lg = 2 %}
{% assign item_multiplier_portrait = 3 %}
{% assign item_multiplier_lg_portrait = 4 %}
{% endif %}
{% assign _i    = 1  | times: item_multiplier %}
{% assign _i_lg = 2  | times: item_multiplier_lg %}
{% assign _i_portrait = 1  | times: item_multiplier_portrait %}
{% assign _i_lg_portrait = 2  | times: item_multiplier_lg_portrait %}


{% render "main",
  trmnl: trmnl,
  data: data,
  img_class: "h--auto h--max-44 lg:h--max-36 md:portrait:hidden",
  cols: 1,
  cols_lg: 2,
  cols_portrait: 1,
  cols_lg_portrait: 1,
  items: _i,
  items_lg: _i_lg,
  items_portrait: _i_portrait,
  items_lg_portrait: _i_lg_portrait,
  desc_clamp: 8,
  desc_clamp_lg: 5,
  desc_clamp_portrait: 5,
  desc_clamp_lg_portrait: 10,
  desc_clamp_boost: 0,
  desc_clamp_boost_lg: 0,
  desc_clamp_boost_portrait: 0,
  desc_clamp_boost_lg_portrait: 0,
  titlebar_instance_class: "hidden",
  show_icon: show_icon,
  movie_icon: movie_icon
   %}
